# vim:ft=gitconfig
#
# Git config template. Substituted at install time by `make setup-git-config`
# with values from ~/.config/dotfiles/identity.env. The output is a real file
# (not a symlink) at ~/.config/git/config so VS Code devcontainers — which
# copy the main config file verbatim but do NOT follow [include] directives —
# see the full config including identity, aliases, and colors.
#
# Placeholders: {{EMAIL}} and {{SIGNINGKEY}}. Edit this template, then run
# `make regen-git-config` to propagate the change. Do NOT edit
# ~/.config/git/config directly — your edits will be lost on the next regen.

[alias]
	br  = branch
	co  = checkout
	cor = "!git for-each-ref --sort=-committerdate --format='%(refname:short) (%(committerdate:relative))' refs/heads | fzf --reverse --nth=1 --preview 'git log --patch --color {1}...{1}~5' | awk '{print $1}' | xargs git checkout"
	cp  = cherry-pick
	cs  = commit -S
	st  = status -sb
	up  = !sh -c 'git pull --rebase --prune && git log --pretty=format:\"%Cred%ae %Creset- %C(yellow)%s %Creset(%ar)\" HEAD@{1}..'

[color]
	ui = true

[color "diff"]
	meta = yellow
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse

[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22

[commit]
	gpgsign = true
	verbose = true

[core]
	editor = nvim
	excludesfile = ~/.config/git/ignore
	pager = diff-so-fancy | less --tabs=4 -RFX
	whitespace = trailing-space,space-before-tab,indent-with-non-tab

[diff]
	colorMoved = default

[difftool]
	prompt = false

[filter "media"]
	clean = git-media-clean %f
	smudge = git-media-smudge %f

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[gc]
	auto = 0

[github]
	user = tarebyte

[init]
	defaultBranch = main

[interactive]
	diffFilter = diff-so-fancy --patch

[protocol]
	version = 2

[pull]
	rebase = true

[push]
	default = current

[user]
	name = Mark Tareshawty
	email = {{EMAIL}}
	signingkey = {{SIGNINGKEY}}

# macOS-only credential helper and gpg program path. Stowed from the
# darwin package; absent on Linux and inside Linux devcontainers, where
# this [include] silently no-ops.
[include]
	path = ~/.config/git/config.darwin
