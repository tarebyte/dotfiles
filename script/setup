#!/bin/sh
#
# Bootstrap entry point. Auto-run by GitHub Codespaces from within the
# pre-cloned dotfiles directory; run manually on a fresh macOS machine
# after `git clone`.
#
# Fresh machine with no clone yet, one-liner:
#   sh -c "$(curl -fsLS get.chezmoi.io)" -- init --apply tarebyte

set -e

REPO="$(cd "$(dirname "$0")/.." && pwd)"

if ! command -v chezmoi >/dev/null 2>&1; then
	BINDIR="$HOME/.local/bin"
	mkdir -p "$BINDIR"
	sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$BINDIR"
	PATH="$BINDIR:$PATH"
	export PATH
fi

chezmoi init --apply --source "$REPO"
