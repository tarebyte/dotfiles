#!/bin/bash
#
# Install CLI tools GitHub Codespaces doesn't ship by default:
# neovim, ripgrep, bat, fzf, lazygit, diff-so-fancy, tree-sitter, tmux.
# Invoked by `make install-codespaces`. Safe to re-run — each step
# no-ops if its binary is already on PATH.

set -euo pipefail

mkdir -p "$HOME/.local/state/dotfiles"
# Capture tee's PID so we can wait on it specifically at exit.
# The process substitution keeps tee alive until stdout closes, which
# happens naturally when the script exits — no explicit wait needed
# for correctness, but we want the final echo to flush before the
# shell tears down the pipe.
exec > >(tee -i "$HOME/.local/state/dotfiles/bootstrap.log")
exec 2>&1

echo "==> Running Codespaces bootstrap..."

ARCH=$(dpkg --print-architecture 2>/dev/null || echo "amd64")
case "$ARCH" in
  amd64) ARCH_ALT="x86_64" ; ARCH_GO="amd64" ;;
  arm64) ARCH_ALT="arm64"  ; ARCH_GO="arm64" ;;
  *) echo "Unsupported architecture: $ARCH" && exit 1 ;;
esac

LOCAL_BIN="$HOME/.local/bin"
mkdir -p "$LOCAL_BIN"

tool_version() {
  local ver
  ver=$("$1" --version 2>&1 | head -1 || true)
  echo "${ver:-unknown}"
}

echo "==> Installing tools (arch: $ARCH)..."

if command -v nvim >/dev/null 2>&1; then
  echo "  ✓ Neovim already installed ($(tool_version nvim))"
else
  start=$SECONDS
  echo "  Installing Neovim..."
  gh release download --clobber --dir /tmp/ --repo neovim/neovim \
    --pattern "nvim-linux-${ARCH_ALT}.tar.gz"
  echo "    sudo: extracting to /opt/nvim..."
  sudo mkdir -p /opt/nvim
  sudo tar -xzf "/tmp/nvim-linux-${ARCH_ALT}.tar.gz" --strip-components=1 -C /opt/nvim
  sudo ln -sf /opt/nvim/bin/nvim /usr/local/bin/nvim
  rm -f "/tmp/nvim-linux-${ARCH_ALT}.tar.gz"
  echo "  ✓ Neovim installed ($(tool_version nvim), $((SECONDS - start))s)"
fi

if command -v rg >/dev/null 2>&1; then
  echo "  ✓ ripgrep already installed ($(tool_version rg))"
else
  start=$SECONDS
  echo "  Installing ripgrep..."
  gh release download --clobber --output /tmp/ripgrep.deb --repo BurntSushi/ripgrep \
    --pattern "ripgrep_*_${ARCH_GO}.deb"
  echo "    sudo: installing .deb package..."
  sudo dpkg -i /tmp/ripgrep.deb
  rm -f /tmp/ripgrep.deb
  echo "  ✓ ripgrep installed ($(tool_version rg), $((SECONDS - start))s)"
fi

if command -v bat >/dev/null 2>&1; then
  echo "  ✓ bat already installed ($(tool_version bat))"
else
  start=$SECONDS
  echo "  Installing bat..."
  gh release download --clobber --output /tmp/bat.deb --repo sharkdp/bat \
    --pattern "bat_*_${ARCH}.deb"
  echo "    sudo: installing .deb package..."
  sudo dpkg -i /tmp/bat.deb
  rm -f /tmp/bat.deb
  echo "  ✓ bat installed ($(tool_version bat), $((SECONDS - start))s)"
fi

if command -v fzf >/dev/null 2>&1; then
  echo "  ✓ fzf already installed ($(tool_version fzf))"
else
  start=$SECONDS
  echo "  Installing fzf..."
  gh release download --clobber --output /tmp/fzf.tar.gz --repo junegunn/fzf \
    --pattern "fzf-*-linux_${ARCH_GO}.tar.gz"
  tar -xzf /tmp/fzf.tar.gz -C /tmp/
  install /tmp/fzf "$LOCAL_BIN/fzf"
  rm -f /tmp/fzf.tar.gz /tmp/fzf
  echo "  ✓ fzf installed ($(tool_version fzf), $((SECONDS - start))s)"
fi

if command -v lazygit >/dev/null 2>&1; then
  echo "  ✓ lazygit already installed ($(lazygit --version 2>&1 | sed -n 's/.*, version=\([^,]*\).*/\1/p' || tool_version lazygit))"
else
  start=$SECONDS
  echo "  Installing lazygit..."
  gh release download --clobber --output /tmp/lazygit.tar.gz --repo jesseduffield/lazygit \
    --pattern "lazygit_*_linux_${ARCH_ALT}.tar.gz"
  tar -xzf /tmp/lazygit.tar.gz -C /tmp/
  install /tmp/lazygit "$LOCAL_BIN/lazygit"
  rm -f /tmp/lazygit.tar.gz /tmp/lazygit
  echo "  ✓ lazygit installed ($(lazygit --version 2>&1 | sed -n 's/.*, version=\([^,]*\).*/\1/p' || tool_version lazygit), $((SECONDS - start))s)"
fi

if command -v diff-so-fancy >/dev/null 2>&1; then
  echo "  ✓ diff-so-fancy already installed ($(diff-so-fancy --version 2>&1 | sed -n 's/.*Version[[:space:]]*:[[:space:]]*//p' || tool_version diff-so-fancy))"
else
  start=$SECONDS
  echo "  Installing diff-so-fancy..."
  gh release download --clobber --output /tmp/diff-so-fancy --repo so-fancy/diff-so-fancy \
    --pattern "diff-so-fancy"
  install /tmp/diff-so-fancy "$LOCAL_BIN/diff-so-fancy"
  rm -f /tmp/diff-so-fancy
  echo "  ✓ diff-so-fancy installed ($(diff-so-fancy --version 2>&1 | sed -n 's/.*Version[[:space:]]*:[[:space:]]*//p' || tool_version diff-so-fancy), $((SECONDS - start))s)"
fi

if command -v tree-sitter >/dev/null 2>&1; then
  echo "  ✓ tree-sitter already installed ($(tool_version tree-sitter))"
else
  start=$SECONDS
  echo "  Installing tree-sitter-cli..."
  case "$ARCH_GO" in
    amd64) TS_ARCH="x64"  ;;
    arm64) TS_ARCH="arm64" ;;
  esac
  gh release download --clobber --output /tmp/tree-sitter.gz --repo tree-sitter/tree-sitter \
    --pattern "tree-sitter-linux-${TS_ARCH}.gz"
  gunzip -f /tmp/tree-sitter.gz
  install /tmp/tree-sitter "$LOCAL_BIN/tree-sitter"
  rm -f /tmp/tree-sitter
  echo "  ✓ tree-sitter installed ($(tool_version tree-sitter), $((SECONDS - start))s)"
fi

if command -v tmux >/dev/null 2>&1; then
  echo "  ✓ tmux already installed ($(tool_version tmux))"
else
  start=$SECONDS
  echo "  Installing tmux..."
  gh release download --clobber --output /tmp/tmux.appimage --repo nelsonenzo/tmux-appimage \
    --pattern "tmux.appimage"
  chmod +x /tmp/tmux.appimage
  cd /tmp && /tmp/tmux.appimage --appimage-extract >/dev/null 2>&1
  install /tmp/squashfs-root/usr/bin/tmux "$LOCAL_BIN/tmux"
  rm -rf /tmp/tmux.appimage /tmp/squashfs-root
  cd - >/dev/null
  echo "  ✓ tmux installed ($(tool_version tmux), $((SECONDS - start))s)"
fi

echo ""
echo "==> Bootstrap complete! Restart your terminal or run: source ~/.bash_aliases"
