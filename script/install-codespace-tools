#!/bin/bash
#
# Install CLI tools GitHub Codespaces doesn't ship by default:
# neovim, ripgrep, bat, fzf, lazygit, diff-so-fancy, tree-sitter.
# Invoked by `make install-codespaces`. Safe to re-run — each step
# no-ops if its binary is already on PATH.

set -euo pipefail

mkdir -p "$HOME/.local/state/dotfiles"
exec > >(tee -i "$HOME/.local/state/dotfiles/bootstrap.log")
exec 2>&1

echo "==> Running Codespaces bootstrap..."

ARCH=$(dpkg --print-architecture 2>/dev/null || echo "amd64")
case "$ARCH" in
  amd64) ARCH_ALT="x86_64" ; ARCH_GO="amd64" ;;
  arm64) ARCH_ALT="arm64"  ; ARCH_GO="arm64" ;;
  *) echo "Unsupported architecture: $ARCH" && exit 1 ;;
esac

echo "==> Installing tools (arch: $ARCH)..."

if ! command -v nvim >/dev/null 2>&1; then
  echo "  Installing Neovim..."
  gh release download --clobber --dir /tmp/ --repo neovim/neovim \
    --pattern "nvim-linux-${ARCH_ALT}.tar.gz" --latest
  sudo mkdir -p /opt/nvim
  sudo tar -xzf "/tmp/nvim-linux-${ARCH_ALT}.tar.gz" --strip-components=1 -C /opt/nvim
  sudo ln -sf /opt/nvim/bin/nvim /usr/local/bin/nvim
  rm -f "/tmp/nvim-linux-${ARCH_ALT}.tar.gz"
fi

if ! command -v rg >/dev/null 2>&1; then
  echo "  Installing ripgrep..."
  gh release download --clobber --output /tmp/ripgrep.deb --repo BurntSushi/ripgrep \
    --pattern "ripgrep_*_${ARCH_GO}.deb" --latest
  sudo dpkg -i /tmp/ripgrep.deb
  rm -f /tmp/ripgrep.deb
fi

if ! command -v bat >/dev/null 2>&1; then
  echo "  Installing bat..."
  gh release download --clobber --output /tmp/bat.deb --repo sharkdp/bat \
    --pattern "bat_*_${ARCH}.deb" --latest
  sudo dpkg -i /tmp/bat.deb
  rm -f /tmp/bat.deb
fi

if ! command -v fzf >/dev/null 2>&1; then
  echo "  Installing fzf..."
  gh release download --clobber --output /tmp/fzf.tar.gz --repo junegunn/fzf \
    --pattern "fzf-*-linux_${ARCH_GO}.tar.gz" --latest
  tar -xzf /tmp/fzf.tar.gz -C /tmp/
  sudo install /tmp/fzf /usr/local/bin/fzf
  rm -f /tmp/fzf.tar.gz /tmp/fzf
fi

if ! command -v lazygit >/dev/null 2>&1; then
  echo "  Installing lazygit..."
  gh release download --clobber --output /tmp/lazygit.tar.gz --repo jesseduffield/lazygit \
    --pattern "lazygit_*_linux_${ARCH_ALT}.tar.gz" --latest
  tar -xzf /tmp/lazygit.tar.gz -C /tmp/
  sudo install /tmp/lazygit /usr/local/bin/lazygit
  rm -f /tmp/lazygit.tar.gz /tmp/lazygit
fi

if ! command -v diff-so-fancy >/dev/null 2>&1; then
  echo "  Installing diff-so-fancy..."
  git clone --depth 1 https://github.com/so-fancy/diff-so-fancy.git /tmp/diff-so-fancy
  sudo mkdir -p /usr/local/bin/lib/
  sudo install /tmp/diff-so-fancy/diff-so-fancy /usr/local/bin/diff-so-fancy
  sudo install /tmp/diff-so-fancy/lib/DiffHighlight.pm /usr/local/bin/lib/DiffHighlight.pm
  rm -rf /tmp/diff-so-fancy
fi

if ! command -v tree-sitter >/dev/null 2>&1; then
  if command -v cargo >/dev/null 2>&1; then
    echo "  Installing tree-sitter-cli..."
    cargo install tree-sitter-cli
  else
    echo "  Skipping tree-sitter-cli (cargo not available)..."
  fi
fi

# Wait for the tee subprocess to drain its buffer before exit, so the
# last lines of the log don't get lost when bash's exec-redirect races.
wait 2>/dev/null || true

echo ""
echo "==> Bootstrap complete! Restart your terminal or run: source ~/.bash_aliases"
