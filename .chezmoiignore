{{/* .chezmoiignore — target paths chezmoi should NOT apply to $HOME. */}}

# Repo-management files visible at source root.
# (Files starting with "." at source root — .github, .gitignore, .git —
# are auto-ignored by chezmoi, so they don't need listing here.)
README.md
CLAUDE.md
LICENSE
script
script/**

# Per-OS targets (note: patterns match target paths, NOT source paths,
# so entries use ".bash_aliases" rather than "dot_bash_aliases".)
{{- if ne .chezmoi.os "linux" }}
.bash_aliases
.oh-my-zsh
.oh-my-zsh/**
.bin/gh-prepare
{{- end }}
{{- if ne .chezmoi.os "darwin" }}
.Brewfile
.bin/pb-pem
.bin/ssh-copy-id
.bin/touchid-enable-pam-sudo
{{- end }}
